          await refreshUser();
          setWelcomeName(name);
          setShowWelcome(true);
          setShowRegister(false);
        }}
      />

      <WelcomeModal
        show={showWelcome}
        onClose={() => setShowWelcome(false)}
        userName={welcomeName}
