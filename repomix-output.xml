    width: 100%;
}

.page-background-padded {
    background-image: url("../assets/pdi/fondo2.png");
    background-size: cover;
    background-position: center;
    background-repeat: no-repeat;
    background-attachment: fixed;
    min-height: 100vh;
    width: 100%;
    padding: 20px 0;
}

/* ==================== CONTAINERS ==================== */
.page-container {
    min-height: calc(100vh - 80px);
    background-color: transparent;
    padding: 40px 20px;
    display: flex;
    justify-content: center;
    align-items: center;
}

.page-container-full {
    max-width: 1400px;
    margin: 40px auto;
    padding: 40px;
    background-color: #ffffff;
    border-radius: 15px;
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.15);
}

/* ==================== CARDS ==================== */
.page-card {
    background-color: white;
    border-radius: 15px;
    padding: 40px;
    max-width: 600px;
    width: 100%;
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.2);
}

.page-card-large {
    background-color: white;
    border-radius: 15px;
    padding: 40px;
    max-width: 900px;
    width: 100%;
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.2);
}

/* ==================== TITLES ==================== */
.page-title {
    color: #2D9CDB;
    font-family: 'Poppins', sans-serif;
    font-weight: 700;
    font-size: 2rem;
    margin-bottom: 30px;
    text-align: center;
}

.page-subtitle {
    color: #555;
    font-family: 'Poppins', sans-serif;
    font-weight: 500;
    font-size: 1.2rem;
    margin-bottom: 20px;
    text-align: center;
}

/* ==================== FORM GROUPS ==================== */
.page-form-group {
    margin-bottom: 20px;
}

.page-form-label {
    display: block;
    margin-bottom: 8px;
    color: #333;
    font-weight: 600;
    font-family: 'Poppins', sans-serif;
}

.page-form-input,
.page-form-select,
.page-form-textarea {
    width: 100%;
    padding: 12px 16px;
    border: 2px solid #e0e0e0;
    border-radius: 8px;
    font-size: 1rem;
    font-family: 'Poppins', sans-serif;
    transition: border-color 0.2s;
}

.page-form-input:focus,
.page-form-select:focus,
.page-form-textarea:focus {
    outline: none;
    border-color: #2D9CDB;
}

.page-form-input:disabled,
.page-form-select:disabled,
.page-form-textarea:disabled {
    background-color: #f5f5f5;
    cursor: not-allowed;
}

/* ==================== BUTTONS ==================== */
.page-btn-primary {
    background-color: #2D9CDB;
    color: white;
    border: none;
    padding: 14px 40px;
    border-radius: 8px;
    font-size: 1.1rem;
    font-weight: 600;
    font-family: 'Poppins', sans-serif;
    cursor: pointer;
    transition: background-color 0.2s, transform 0.1s;
}

.page-btn-primary:hover:not(:disabled) {
    background-color: #2589c4;
    transform: translateY(-2px);
}

.page-btn-primary:active:not(:disabled) {
    transform: translateY(0);
}

.page-btn-primary:disabled {
    background-color: #cccccc;
    cursor: not-allowed;
}

.page-btn-actions {
    margin-top: 30px;
    display: flex;
    justify-content: center;
    gap: 15px;
}

/* ==================== GRID LAYOUTS ==================== */
.page-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 30px;
    max-width: 100%;
}

/* Limitar a 3 columnas máximo */
@media (min-width: 1200px) {
    .page-grid {
        grid-template-columns: repeat(3, 1fr);
    }
}

/* 2 columnas en tablets */
@media (max-width: 1199px) and (min-width: 768px) {
    .page-grid {
        grid-template-columns: repeat(2, 1fr);
    }
}

/* 1 columna en móviles */
@media (max-width: 767px) {
    .page-grid {
        grid-template-columns: 1fr;
    }
}

/* ==================== LOADING & EMPTY STATES ==================== */
.page-loading {
    display: flex;
    justify-content: center;
    align-items: center;
    min-height: 400px;
    font-size: 1.2rem;
    color: #666;
    font-family: 'Poppins', sans-serif;
}

.page-empty {
