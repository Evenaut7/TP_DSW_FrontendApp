    margin: 30px 0;
    border: none;
}

/* Padding para páginas con Navbar fijo superpuesto */
.page-with-navbar-padding {
    padding-top: 110px;
}

@media (min-width: 768px) {
    .page-with-navbar-padding {
        padding-top: 90px;
    }
}
