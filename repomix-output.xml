   PAGE LAYOUT - Estilos compartidos para páginas
   ============================================================ */

/* ==================== BACKGROUNDS ==================== */

/* Estilo base para páginas con fondo */
.page-background {
    background-image: url("../assets/pdi/fondo2.png");
    background-size: cover;
    background-position: center;
    background-repeat: no-repeat;
    background-attachment: fixed;
