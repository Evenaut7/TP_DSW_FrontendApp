    opacity: 0.3;
}

.page-empty-text {
    font-size: 1.2rem;
    margin-bottom: 10px;
}

/* ==================== RESPONSIVE ==================== */
@media (max-width: 768px) {
    .page-container {
        padding: 20px 10px;
    }

    .page-container-full {
        margin: 20px;
        padding: 25px;
    }

    .page-card,
    .page-card-large {
        padding: 25px;
    }

    .page-title {
        font-size: 1.5rem;
    }

    .page-subtitle {
        font-size: 1rem;
    }

    .page-btn-primary {
        padding: 12px 30px;
        font-size: 1rem;
    }
}

/* ==================== UTILITIES ==================== */
.page-text-center {
    text-align: center;
}

.page-text-error {
    color: #dc3545;
    font-family: 'Poppins', sans-serif;
    margin-bottom: 20px;
}

.page-text-success {
    color: #28a745;
